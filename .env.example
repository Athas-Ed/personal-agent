# DeepSeek (OpenAI-compatible) configuration
# 二选一即可（两套命名都支持）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 或者用 OpenAI 兼容命名
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Models (adjust as needed)
CHAT_MODEL=deepseek-chat
EMBED_MODEL=deepseek-embedding

# App settings
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=personal_workbench

# Proxy（可选）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost

# 如果你的代理环境触发 TLS 校验失败，可临时关闭校验（不建议长期使用）
OPENAI_SSL_VERIFY=1

# Watt/SteamTools 加速器证书（可选，用于代理 MITM 场景下的 TLS 校验）
WATT_CA_CERT=C:\path\to\SteamTools.Certificate.cer

# AMap (Gaode) Weather API (recommended for CN network)
# Get key from AMap console, then set:
AMAP_KEY=your_amap_key_here
